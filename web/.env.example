# Supabase Postgres — use "Connection string" → URI, or pooler (port 6543) for serverless
# Project ref: https://xxxx.supabase.co → Settings → Database
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Must match legacy Express + encrypted keys in DB (64 hex chars)
ENCRYPTION_KEY=

# JWT for admin API (same contract as legacy: Bearer token from POST /api/auth/login)
JWT_SECRET=

# Solana (approve / treasury)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
TREASURY_PRIVATE_KEY=

# Optional caps
MAX_PRIZE_PER_HOTSPOT_SOL=1000
MAX_DAILY_TREASURY_OUT_SOL=10000

# Optional geocoding (hotspot create)
GOOGLE_GEOCODING_API_KEY=

# Public site URL (browser → API if ever needed client-side)
NEXT_PUBLIC_APP_URL=http://localhost:3000
