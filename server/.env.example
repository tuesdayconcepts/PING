# Copy to .env: cp .env.example .env
NODE_ENV=development
PORT=8080
DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/DBNAME
JWT_SECRET=change-me
# 64 hex chars (32 bytes): node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
# Optional: Solana / treasury (required for on-chain features)
# SOLANA_RPC_URL=
# TREASURY_PRIVATE_KEY=
# Optional: push (VAPID_*) and geocoding keys as in README
