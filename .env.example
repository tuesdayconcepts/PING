# --- Next.js (public, exposed to the browser) ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_GEOCODING_API_KEY=
NEXT_PUBLIC_SOLANA_RPC_URL=

# --- Database (Supabase Postgres) ---
# Supabase → Project Settings → Database → Connection string (URI)
# Use the "Transaction" pooler URL for serverless if recommended by Supabase.
DATABASE_URL=

# --- Optional: Supabase client SDK (auth, storage, Realtime) ---
# Data tables are still accessed via Prisma using DATABASE_URL above.
# Add these when you wire Supabase Auth or other Supabase APIs (see `src/server/supabase.ts`).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only; never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Legacy API (server-side secrets used by `src/server/legacy/*`) ---
JWT_SECRET=
ENCRYPTION_KEY=

# Solana treasury funding (used by approval flow)
SOLANA_RPC_URL=
TREASURY_PRIVATE_KEY=

# Optional caps / thresholds
MAX_PRIZE_PER_HOTSPOT_SOL=1000
MAX_DAILY_TREASURY_OUT_SOL=10000
LOW_BALANCE_THRESHOLD_SOL=1.0

# Push notifications (optional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# CORS (comma-separated origins). For Vercel previews you may want `*`.
ALLOWED_ORIGINS=

# Google geocoding for server-side reverse geocode (optional; falls back to NEXT_PUBLIC keys in legacy code)
GOOGLE_GEOCODING_API_KEY=
